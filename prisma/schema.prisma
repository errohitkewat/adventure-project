generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  phone         String
  email         String
  activityName  String
  travelDate    String
  persons       Int
  message       String?
  packageType   String
  packageLabel  String
  basePrice     Int
  addons        String
  addonTotal    Int
  grandTotal    Int
  status        String   @default("pending")
  scheduledFor  String?
  adminNotes    String?
  createdAt     DateTime @default(now())
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  publicId  String?
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  name       String
  role       String
  review     String
  rating     Int
  approved   Boolean  @default(false)
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())
}